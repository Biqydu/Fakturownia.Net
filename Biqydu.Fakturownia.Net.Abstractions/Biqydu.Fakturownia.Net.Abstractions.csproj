<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <Version>1.0.1</Version>
        <Authors>Biqydu</Authors>
        <Description>Abstractions and data models for Fakturownia.pl SDK.</Description>
        <PackageTags>fakturownia;invoice;api;models</PackageTags>
